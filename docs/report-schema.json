{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/mcp-verify/report-schema/v1.0",
  "title": "MCP Verify Report Schema",
  "description": "Schema for mcp-verify JSON report output (version 1.0)",
  "type": "object",
  "required": ["schemaVersion", "meta", "conformance", "security", "summary"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0",
      "description": "Report schema version. Always '1.0' for this iteration."
    },
    "meta": {
      "type": "object",
      "required": [
        "toolVersion",
        "specVersion",
        "timestamp",
        "target",
        "transport",
        "durationMs",
        "checkMode",
        "thresholds"
      ],
      "additionalProperties": false,
      "properties": {
        "toolVersion": {
          "type": "string",
          "description": "Version of the mcp-verify tool that generated this report."
        },
        "specVersion": {
          "type": "string",
          "description": "MCP specification version checked against (e.g. '2024-11-05')."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of when the verification was performed."
        },
        "target": {
          "type": "string",
          "description": "Target MCP server URL or stdio command that was verified."
        },
        "transport": {
          "type": "string",
          "enum": ["http", "stdio"],
          "description": "Transport protocol used to communicate with the server."
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0,
          "description": "Total wall-clock time of the verification run in milliseconds."
        },
        "checkMode": {
          "type": "string",
          "enum": ["balanced", "strict", "lenient"],
          "description": "Check strictness mode used during verification."
        },
        "thresholds": {
          "type": "object",
          "required": ["conformanceThreshold", "failOnSeverity"],
          "additionalProperties": false,
          "properties": {
            "conformanceThreshold": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "description": "Minimum conformance score required to pass (0–100)."
            },
            "failOnSeverity": {
              "type": "string",
              "enum": ["critical", "high", "medium", "low", "none"],
              "description": "Minimum security finding severity that causes a failure."
            }
          }
        }
      }
    },
    "conformance": {
      "type": "object",
      "required": ["score", "breakdown", "violations"],
      "additionalProperties": false,
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Overall weighted conformance score (0–100)."
        },
        "breakdown": {
          "type": "object",
          "description": "Per-category conformance scores keyed by category identifier.",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          }
        },
        "violations": {
          "type": "array",
          "description": "All non-passing check results (failures, warnings, and info items).",
          "items": {
            "$ref": "#/$defs/checkResult"
          }
        }
      }
    },
    "security": {
      "type": "object",
      "required": ["findings", "suppressed"],
      "additionalProperties": false,
      "properties": {
        "findings": {
          "type": "array",
          "description": "Active (non-suppressed) security findings.",
          "items": {
            "$ref": "#/$defs/securityFinding"
          }
        },
        "suppressed": {
          "type": "array",
          "description": "Security findings that were suppressed via configuration.",
          "items": {
            "$ref": "#/$defs/securityFinding"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["pass", "exitCode", "blockerCount"],
      "additionalProperties": false,
      "properties": {
        "pass": {
          "type": "boolean",
          "description": "True when the server passed all configured thresholds."
        },
        "exitCode": {
          "type": "integer",
          "enum": [0, 1, 2],
          "description": "Process exit code: 0=pass, 1=fail, 2=error."
        },
        "blockerCount": {
          "type": "object",
          "description": "Count of active security findings grouped by severity.",
          "properties": {
            "critical": { "type": "integer", "minimum": 0 },
            "high": { "type": "integer", "minimum": 0 },
            "medium": { "type": "integer", "minimum": 0 },
            "low": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    }
  },
  "$defs": {
    "checkResult": {
      "type": "object",
      "required": [
        "checkId",
        "name",
        "category",
        "level",
        "description",
        "specVersion",
        "specReference",
        "confidence"
      ],
      "additionalProperties": true,
      "properties": {
        "checkId": { "type": "string" },
        "name": { "type": "string" },
        "category": {
          "type": "string",
          "enum": [
            "jsonrpc-base",
            "initialization",
            "tools",
            "resources",
            "prompts",
            "transport",
            "error-handling"
          ]
        },
        "level": {
          "type": "string",
          "enum": ["pass", "failure", "warning", "info"]
        },
        "description": { "type": "string" },
        "specVersion": { "type": "string" },
        "specReference": { "type": "string" },
        "field": { "type": "string" },
        "messageId": { "type": ["string", "number"] },
        "confidence": {
          "type": "string",
          "enum": ["deterministic", "high", "medium", "low"]
        },
        "details": { "type": "object" }
      }
    },
    "securityFinding": {
      "type": "object",
      "required": [
        "id",
        "checkId",
        "severity",
        "cvssScore",
        "component",
        "title",
        "description",
        "remediation",
        "confidence",
        "suppressed"
      ],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "checkId": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "cvssScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "component": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "remediation": { "type": "string" },
        "confidence": {
          "type": "string",
          "enum": ["deterministic", "heuristic"]
        },
        "evidence": { "type": "object" },
        "suppressed": { "type": "boolean" }
      }
    }
  }
}
